# Model weights (keep structure)
weights/*.pth
weights/*.pt
weights/*.onnx
weights/*.ckpt
!weights/.gitkeep

# Outputs — track experiment logs (small text), ignore model weights (large binary)
outputs/*/best_model.pth
outputs/*/*.pth
outputs/*/checkpoints/
# Keep .gitkeep and label_mapping.json trackable
!outputs/.gitkeep
!outputs/label_mapping.json
experiments/*/
!experiments/.gitkeep
!experiments/lqh/
!experiments/exp_021*/
!experiments/exp_022*/
!experiments/exp_023*/

# Reports
reports/*.csv
reports/*.html
!reports/.gitkeep

